rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User's private data - only accessible by the owning user
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Compliance data - readable by admin, writable by owning user
    match /compliance/{userId}/{document=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.admin == true
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Feedback collections - writable by any authenticated user, readable by admin
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
    match /bugReports/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
    match /featureRequests/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
    match /conditionRequests/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
